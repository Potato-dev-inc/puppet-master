{
  "name": "@puppet-master/mcp",
  "version": "0.1.1",
  "description": "Puppet Master MCP server — stdio JSON-RPC bridge to the local HTTP bridge",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "puppet-master-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.1",
    "esbuild": "0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
