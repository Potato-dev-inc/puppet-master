{
  "name": "@puppet-master/mcp",
  "version": "0.1.3",
  "description": "Puppet Master MCP server — stdio JSON-RPC bridge to the local HTTP bridge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Potato-dev-inc/puppet-master.git",
    "directory": "packages/mcp-server"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "puppet-master-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:legacy && npm run build:launcher && npm run build:rust",
    "build:legacy": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/legacy.js",
    "build:launcher": "esbuild src/launcher.ts --bundle --platform=node --format=esm --outfile=dist/index.js",
    "build:rust": "node ../../scripts/build-rust-mcp.mjs",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "esbuild": "0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
