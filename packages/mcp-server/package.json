{
  "name": "@puppet-master/mcp",
  "version": "0.1.1",
  "description": "Puppet Master MCP server — stdio JSON-RPC bridge to the local HTTP bridge",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "puppet-master-mcp": "./dist/index.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@puppet-master/shared": "*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
