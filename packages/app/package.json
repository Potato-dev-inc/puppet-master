{
  "name": "@puppet-master/app",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/ensure-workspace-built.mjs",
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build && node ../../scripts/bundle-cloudflared.mjs && node ../../scripts/stage-pwa-dist.mjs && node ../../scripts/bundle-mcp.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@puppet-master/shared": "*",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.0.1",
    "@tauri-apps/plugin-store": "^2.0.1",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-unicode11": "0.9.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "html5-qrcode": "2.3.8",
    "qrcode": "1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/qrcode": "1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "esbuild": "^0.25.0",
    "jsdom": "^26.1.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "^3.2.4"
  }
}
